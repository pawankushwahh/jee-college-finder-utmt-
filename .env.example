# Copy to .env and adjust for your environment.

# Comma-separated list of frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to the basic cutoff workbook (sir-provided, OPEN seats only, 2025).
# Relative paths resolve against project root.
DATA_PATH=app/disha/data/JEE_2025_Cutoffs.xlsx

# Path to the extended merged CSV (all categories, 2018-2025).
# Only required if you want the Extended data mode to work.
EXTENDED_DATA_PATH=app/disha/data/merged_jee_cutoff_2018_2025.csv

# Default data mode. "basic" = OPEN seats only (Excel file).
# "extended" = all categories from the merged CSV.
DATA_MODE=basic

# Set to False to lock the mode to DATA_MODE above and hide the UI toggle.
# Useful for classroom / demo deployments where you want a fixed dataset.
ALLOW_USER_DATA_TOGGLE=True
